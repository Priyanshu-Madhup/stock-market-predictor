# Copy this file to .env and fill in your values.
# The real .env is git-ignored and must NOT be committed.

# Get your API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Any model slug from https://console.groq.com/docs/models
# Recommended: openai/gpt-oss-20b  |  llama-3.3-70b-versatile  |  gemma2-9b-it
GROQ_MODEL=openai/gpt-oss-20b
